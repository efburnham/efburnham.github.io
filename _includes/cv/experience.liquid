{% comment %}
  Unified work/experience entry renderer for both RenderCV and JSONResume formats.
  Handles RenderCV fields like company, position, role, course, institution,
  organization, location, start_date, end_date, date, url, summary, highlights.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item" style="list-style: none;">
      <div class="row">
        <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column" style="width: 100px; flex: 0 0 100px;">
          {% capture start_date %}
            {% if entry.start_date %}{{ entry.start_date | strip }}{% elsif entry.startDate %}{{ entry.startDate | strip }}{% elsif entry.date %}{{ entry.date | strip }}{% endif %}
          {% endcapture %}
          {% assign start_date = start_date | strip %}
          {% capture end_date %}
            {% if entry.end_date %}{{ entry.end_date | strip }}{% elsif entry.endDate %}{{ entry.endDate | strip }}{% endif %}
          {% endcapture %}
          {% assign end_date = end_date | strip %}

          {% capture start_year %}{{ start_date | split: '-' | first | strip }}{% endcapture %}
          {% capture end_year %}{{ end_date | split: '-' | first | strip }}{% endcapture %}

          {% if start_date != '' and end_date != '' and start_year == end_year %}
            {% assign date = start_year %}
          {% elsif start_date != '' and end_date != '' %}
            {% assign date = start_year | append: ' - ' | append: end_year %}
          {% elsif start_date != '' %}
            {% assign date = start_date %}
          {% else %}
            {% assign date = '' %}
          {% endif %}

          <table class="table-cv" style="width: 100%;">
            <tbody>
              <tr>
                <td>
                  <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="width: 100%; text-align: center;">{{ date }}</span>
                </td>
              </tr>
              {% capture location %}
                {% if entry.location %}{{ entry.location }}{% endif %}
              {% endcapture %}
              {% if location != '' %}
                <tr>
                  <td>
                    <p class="location">
                      <i class="fa-solid fa-location-dot iconlocation"></i>
                      {{ location }}
                    </p>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>

        <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
          {% capture position_title %}
            {% if entry.position %}{{ entry.position }}{% elsif entry.role and entry.course %}{{ entry.role }}: {{ entry.course }}{% elsif entry.role %}{{ entry.role }}{% elsif entry.course %}{{ entry.course }}{% elsif entry.title %}{{ entry.title }}{% endif %}
          {% endcapture %}

          {% if entry.url and position_title != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4"><a href="{{ entry.url }}">{{ position_title }}</a></h6>
          {% elsif position_title != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">{{ position_title }}</h6>
          {% endif %}

          {% capture company_name %}
            {% if entry.name %}{{ entry.name }}{% elsif entry.company %}{{ entry.company }}{% elsif entry.institution %}{{ entry.institution }}{% elsif entry.organization %}{{ entry.organization }}{% endif %}
          {% endcapture %}
          {% if company_name != '' %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">{{ company_name }}</h6>
          {% endif %}

          {% if entry.summary %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">
              {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
            </h6>
          {% elsif entry.course and entry.role %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">
              {{ entry.role }} for {{ entry.course }}
            </h6>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items">
              {% for item in entry.highlights %}
                <li style="list-style: none;">
                  <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
